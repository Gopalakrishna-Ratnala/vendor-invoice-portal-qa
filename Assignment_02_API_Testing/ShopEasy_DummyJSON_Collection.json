{
  "info": {
    "name": "ShopEasy API Testing — DummyJSON (QA Excellence Assignment 2)",
    "description": "Postman collection demonstrating the ShopEasy e-commerce API testing challenge (from QA Excellence slides) using DummyJSON as the live test environment.\n\nBase URL: https://dummyjson.com\n\nModules: Authentication · Product Catalog · Shopping Cart · User Management\n12 endpoints × (1 positive + 1 negative) = 24 test requests.\n\nBonus: Collection-level pre-request script auto-fetches and caches the Bearer token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// ================================================================",
          "// BONUS: Auto-set Bearer Token — runs before every request.",
          "// Skips login/register endpoints; re-fetches if missing or expired.",
          "// ================================================================",
          "const skipPaths = ['/auth/login', '/users/add'];",
          "const url = pm.request.url.toString();",
          "if (skipPaths.some(p => url.includes(p))) return;",
          "",
          "const token   = pm.collectionVariables.get('accessToken');",
          "const expiry  = pm.collectionVariables.get('tokenExpiry');",
          "if (token && expiry && Date.now() < parseInt(expiry)) {",
          "    console.log('[Auth] Reusing cached Bearer token.');",
          "    return;",
          "}",
          "",
          "console.log('[Auth] Token missing/expired — fetching new token...');",
          "pm.sendRequest({",
          "    url: pm.collectionVariables.get('baseUrl') + '/auth/login',",
          "    method: 'POST',",
          "    header: { 'Content-Type': 'application/json' },",
          "    body: {",
          "        mode: 'raw',",
          "        raw: JSON.stringify({",
          "            username: pm.collectionVariables.get('username'),",
          "            password: pm.collectionVariables.get('password'),",
          "            expiresInMins: 60",
          "        })",
          "    }",
          "}, function (err, res) {",
          "    if (err) { console.error('[Auth] Login failed:', err); return; }",
          "    const body = res.json();",
          "    if (body && body.accessToken) {",
          "        pm.collectionVariables.set('accessToken', body.accessToken);",
          "        pm.collectionVariables.set('tokenExpiry', String(Date.now() + 55 * 60 * 1000));",
          "        console.log('[Auth] Bearer token cached successfully.');",
          "    } else {",
          "        console.error('[Auth] No token in login response:', JSON.stringify(body));",
          "    }",
          "});"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level: response time guard on all requests",
          "// Using 5000ms threshold — first auth call (cold start) can take ~3s",
          "pm.test('Response time < 5000ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(5000);",
          "});",
          "",
          "// Collection-level: Content-Type should be JSON for all responses",
          "pm.test('Content-Type is application/json', function () {",
          "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
          "});"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl",      "value": "https://dummyjson.com",  "type": "string" },
    { "key": "username",     "value": "emilys",                 "type": "string" },
    { "key": "password",     "value": "emilyspass",             "type": "string" },
    { "key": "accessToken",  "value": "",                       "type": "string" },
    { "key": "tokenExpiry",  "value": "0",                      "type": "string" },
    { "key": "userId",       "value": "1",                      "type": "string" },
    { "key": "productId",    "value": "1",                      "type": "string" },
    { "key": "cartId",       "value": "1",                      "type": "string" },
    { "key": "invalidId",    "value": "99999",                  "type": "string" },
    { "key": "newUserId",    "value": "",                       "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "description": "ShopEasy concept: POST /auth/login · POST /auth/register\nDummyJSON: POST /auth/login · POST /users/add",
      "item": [
        {
          "name": "TC-A01-P | Login — Valid credentials → 200 + accessToken",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-A01-P | Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('TC-A01-P | Response contains accessToken', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('accessToken');",
                  "    pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "    pm.collectionVariables.set('accessToken', body.accessToken);",
                  "    pm.collectionVariables.set('tokenExpiry', String(Date.now() + 55 * 60 * 1000));",
                  "});",
                  "",
                  "pm.test('TC-A01-P | Response contains userId and username', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('username');",
                  "    pm.expect(body).to.have.property('email');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"emilys\",\n  \"password\": \"emilyspass\",\n  \"expiresInMins\": 60\n}"
